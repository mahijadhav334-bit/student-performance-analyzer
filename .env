# ── Flask ──────────────────────────────────────────
# Leave blank to auto-generate a random key on first run
SECRET_KEY=
FLASK_APP=app.py
FLASK_ENV=development

# ── OpenAI (optional, enables AI chat) ────────────
# Free AI Integration (Highly Recommended for going online)
# Get a free key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_real_gemini_key

# OpenAI Fallback (Requires paid plan)
OPENAI_API_KEY=your_real_openai_key

# ── Email / SMTP (optional, enables email reports) ─
MAIL_SERVER=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_USE_TLS=True
MAIL_DEFAULT_SENDER=
